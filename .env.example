# PostgreSQL (example)
DATABASE_URL=postgresql://user:password@localhost:5432/education_fr

# JWT
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS (comma-separated origins, or * for any — dev only)
CORS_ORIGINS=*

# SMTP — leave SMTP_HOST empty to use console fallback (dev mode)
# Works with any SMTP provider (Gmail app-password, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.example.com

# Gmail (port 465, SSL):
#   SMTP_PORT=465  SMTP_USE_SSL=true  SMTP_USE_TLS=false
# Most other providers (port 587, STARTTLS):
#   SMTP_PORT=587  SMTP_USE_SSL=false  SMTP_USE_TLS=true
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_USE_SSL=false
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@delfy.app
SMTP_FROM_NAME=DELFy

# Password reset code TTL in minutes (default: 15)
PASSWORD_RESET_CODE_EXPIRE_MINUTES=15
